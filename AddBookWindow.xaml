<Window x:Class="libraria.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:libraria"
        mc:Ignorable="d"
        Title="Add Book" Height="600" Width="550"
        BorderBrush="{StaticResource AccentColor}"
        Background="{StaticResource PrimaryColor}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0">
            <Border BorderBrush="{StaticResource AccentColor}" BorderThickness="1"
                    Height="300" Background="#FFB6C1" CornerRadius="4">
                <Grid>
                    <TextBlock Text="No Cover" Foreground="{StaticResource AccentColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="CoverImage" Stretch="UniformToFill"/>
                </Grid>
            </Border>
            <Button Content="Browse Image..." Margin="0,20,0,0" Background="#FFB6C1" Foreground="{StaticResource AccentColor}"/>
        </StackPanel>
        <StackPanel Grid.Column="1">
            <TextBlock Text="TITLE" Foreground="{StaticResource AccentColor}" FontSize="15"
                       FontWeight="Bold" Margin="10,10,0,0"/>
            <TextBox x:Name="TitleBox" Background="White" Foreground="{StaticResource AccentColor}" Height="30"
                       Margin="10,10,0,0"/>
            <TextBlock Text="AUTHOR" Foreground="{StaticResource AccentColor}" FontSize="15"
           FontWeight="Bold" Margin="10,10,0,0"/>
            <TextBox x:Name="AuthorBox" Background="White" Foreground="{StaticResource AccentColor}" Height="30"
           Margin="10,10,0,0"/>
            <TextBlock Text="DESCRIPTION" Foreground="{StaticResource AccentColor}" FontSize="15"
           FontWeight="Bold" Margin="10,10,0,0"/>
            <TextBox x:Name="DescriptionBox" Background="White" Foreground="{StaticResource AccentColor}" Height="70"
           Margin="10,10,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Background="#FFB6C1" Foreground="{StaticResource AccentColor}"
                    Width="100" Margin="10,0,10,0"/>
            <Button Content="Save" Background="{StaticResource AccentColor}" Foreground="{StaticResource PrimaryColor}"
                    Width="100">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=TitleBox, Path=Text, UpdateSourceTrigger=PropertyChanged}" Value="">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
