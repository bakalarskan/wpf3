<Window x:Class="libraria.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:libraria"
        mc:Ignorable="d"
        Title="Libraria" Height="650" Width="1000"
        MinHeight="500" MinWidth="920"
        Icon="ikonki/book.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="White" Padding="2">
            <MenuItem Header="Repository"/>
            <MenuItem Header="Book">
                <MenuItem Header="Add..." Click="MenuItem_Click"/>
                <MenuItem Header="Edit..."/>
                <MenuItem Header="Delete..."/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1" Background="{StaticResource PrimaryColor}">
            <StackPanel Orientation="Horizontal">
                <Image Source="ikonki/book.png" Width="48" Height="48"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Libraria"
                               Foreground="{StaticResource AccentColor}"
                               FontSize="25"
                               FontFamily="Segoe Script"/>
                    <TextBlock Text="Personal Book Manager"
                               Foreground="Gray"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Background="White">
            
        </Grid>
        <Grid Grid.Row="3" Background="{StaticResource PrimaryColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Total: 0" Foreground="{StaticResource AccentColor}"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
